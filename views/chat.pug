extends layout

block content
  .row
    .col-md-3
      .card
        .card-header
          h5 Users
        .list-group.list-group-flush#user-list
          each u in users
            a.list-group-item.list-group-item-action(href=`/?user=${u._id}` class=(selectedUser && selectedUser._id.toString() === u._id.toString() ? 'active' : ''))
              | #{u.username}
    
    .col-md-9
      if selectedUser
        .card
          .card-header.bg-white.d-flex.justify-content-between.align-items-center
            h4 Chatting with #{selectedUser.username}
          .card-body#chat-window(style="height: 400px; overflow-y: scroll;")
            each msg in messages
              .mb-2(class=(msg.sender.toString() === user._id.toString() ? 'text-end' : ''))
                .d-inline-block.p-2.rounded(class=(msg.sender.toString() === user._id.toString() ? 'bg-primary text-white' : 'bg-light'))
                  span #{msg.content}
          .card-footer
            form#chat-form
              input(type="hidden" id="userId" value=user._id)
              input(type="hidden" id="receiverId" value=selectedUser._id)
              .input-group
                input.form-control#msg-input(type="text" placeholder="Type a message..." required)
                button.btn.btn-primary(type="submit") Send
      else
        .card
          .card-body.text-center.py-5
            h4 Select a user to start chatting
            p Choose someone from the list on the left to begin a private conversation.

  script(src="/socket.io/socket.io.js")
  script(src="/js/chat.js")
